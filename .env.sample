# Wallet Analyzer environment variables (template)
#
# This project reads configuration from this file.
# Keep this file out of git (see `.gitignore`) to avoid leaking API keys.

# --- Required API keys ---
HELIUS_API_KEY="YOUR_HELIUS_API_KEY"
BIRDEYE_API_KEY="YOUR_BIRDEYE_API_KEY"
BITQUERY_API_KEY="YOUR_BITQUERY_API_KEY"

# --- Optional endpoint overrides (defaults match `main.py`) ---
# HELIUS_RPC_URL can be set directly, otherwise it will be derived from HELIUS_API_KEY.
HELIUS_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY"

BIRDEYE_BASE="https://public-api.birdeye.so"
BITQUERY_URL="https://streaming.bitquery.io/graphql"
DEXSCREENER_BASE="https://api.dexscreener.com/latest/dex"

# --- Rate limiting / retry knobs (defaults match `main.py`) ---
RATE_LIMIT_DELAY="0.5"       # seconds between wallets
MAX_RETRIES="3"              # retry on rate limits / transient errors
REQUEST_TIMEOUT="30"        # HTTP timeout (seconds)
MAX_WORKERS="3"             # concurrency cap (if used)
BITQUERY_DELAY="7"          # seconds between Bitquery requests

# --- Input / output files (defaults match `main.py`) ---
INPUT_FILE="wallets.txt"
PROCESSED_LOG="processed_wallets.log"
FAILED_LOG="failed_wallets.log"
HIGH_VOLUME_CSV="wallets_with_highest_recent_volume.csv"
LOW_VOLUME_CSV="wallets_without_highest_recent_volume.csv"
SUMMARY_FILE="summary_report.txt"
VOLUME_DEBUG_LOG="volume_debug.log"

